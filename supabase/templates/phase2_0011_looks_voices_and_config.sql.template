create table private.voice_version_availability_events (
  command_id uuid primary key,
  voice_version_id uuid not null
    references public.voice_versions(id) on delete restrict,
  idempotency_key text not null unique
    check (idempotency_key ~ '^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$'),
  request_hash text not null check (request_hash ~ '^[a-f0-9]{64}$'),
  prior_status public.voice_version_availability_status not null,
  new_status public.voice_version_availability_status not null,
  aggregate_version bigint not null check (aggregate_version > 1),
  constraint voice_availability_events_no_unattested_verification
    check (new_status <> 'verified'),
  evidence jsonb not null check ((
    jsonb_typeof(evidence) = 'object'
    and new_status = 'withdrawn'
    and (evidence - array['kind','reason','actor']::text[]) = '{}'::jsonb
    and evidence ?& array['kind','reason','actor']
    and jsonb_typeof(evidence -> 'kind') = 'string'
    and jsonb_typeof(evidence -> 'reason') = 'string'
    and jsonb_typeof(evidence -> 'actor') = 'string'
    and evidence ->> 'kind' = 'administrative_withdrawal'
    and char_length(btrim(evidence ->> 'reason')) between 1 and 1000
    and char_length(btrim(evidence ->> 'actor')) between 1 and 200
    and pg_column_size(evidence) <= 65536
  ) is true),
  correlation_id uuid not null,
  created_at timestamptz not null default statement_timestamp(),
  unique (voice_version_id, aggregate_version)
);

create table private.look_version_availability_events (
  command_id uuid primary key,
  look_version_id uuid not null
    references public.look_versions(id) on delete restrict,
  idempotency_key text not null unique
    check (idempotency_key ~ '^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$'),
  request_hash text not null check (request_hash ~ '^[a-f0-9]{64}$'),
  prior_status public.look_version_availability_status not null,
  new_status public.look_version_availability_status not null,
  aggregate_version bigint not null check (aggregate_version > 1),
  evidence jsonb not null check ((
    jsonb_typeof(evidence) = 'object'
    and (evidence - array['kind','reason','actor']::text[]) = '{}'::jsonb
    and evidence ?& array['kind','reason','actor']
    and jsonb_typeof(evidence -> 'kind') = 'string'
    and jsonb_typeof(evidence -> 'reason') = 'string'
    and jsonb_typeof(evidence -> 'actor') = 'string'
    and evidence ->> 'kind' = 'curation_withdrawal'
    and char_length(btrim(evidence ->> 'reason')) between 1 and 1000
    and char_length(btrim(evidence ->> 'actor')) between 1 and 200
