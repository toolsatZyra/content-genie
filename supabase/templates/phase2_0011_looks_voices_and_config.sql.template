create table public.episode_configuration_candidates (
  id uuid primary key default gen_random_uuid(),
  workspace_id uuid not null,
  episode_id uuid not null,
  candidate_number integer not null check (candidate_number > 0),
  script_revision_id uuid not null,
  narrator_gender public.narrator_gender not null default 'male',
  voice_version_id uuid not null,
  look_version_id uuid not null references public.look_versions(id) on delete restrict,
  performance_profile_id text not null
    default 'genie-launch-hindi-delhi-sanskrit-performance.v1'
    check (
      performance_profile_id = 'genie-launch-hindi-delhi-sanskrit-performance.v1'
    ),
  voice_confirmed_by uuid references auth.users(id) on delete restrict,
  voice_confirmed_at timestamptz,
  look_confirmed_by uuid references auth.users(id) on delete restrict,
  look_confirmed_at timestamptz,
  state public.configuration_candidate_state not null default 'world_design',
  aggregate_version bigint not null default 1 check (aggregate_version > 0),
  selected_by uuid not null references auth.users(id) on delete restrict,
  created_at timestamptz not null default statement_timestamp(),
  updated_at timestamptz not null default statement_timestamp(),
  superseded_at timestamptz,
  locked_at timestamptz,
  unique (workspace_id, id),
  unique (workspace_id, episode_id, candidate_number),
  unique (episode_id, candidate_number),
  foreign key (workspace_id, episode_id)
    references public.episodes(workspace_id, id) on delete restrict,
  foreign key (workspace_id, episode_id, script_revision_id)
    references public.script_revisions(workspace_id, episode_id, id)
    on delete restrict,
  foreign key (voice_version_id, narrator_gender)
    references public.voice_versions(id, gender) on delete restrict,
  check ((voice_confirmed_by is null) = (voice_confirmed_at is null)),
  check ((look_confirmed_by is null) = (look_confirmed_at is null)),
  check (
    state not in ('preflight', 'ready_to_lock', 'locked')
    or (
      voice_confirmed_by is not null
      and voice_confirmed_at is not null
      and look_confirmed_by is not null
      and look_confirmed_at is not null
    )
  ),
  check (
    (state = 'superseded' and superseded_at is not null and locked_at is null)
    or (state = 'locked' and locked_at is not null and superseded_at is null)
    or (
      state in ('world_design', 'preflight', 'ready_to_lock')
      and superseded_at is null
      and locked_at is null
    )
  )
);

