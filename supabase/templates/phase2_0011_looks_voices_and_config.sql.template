create or replace function public.command_select_episode_voice(
  p_workspace_id uuid,
  p_episode_id uuid,
  p_configuration_candidate_id uuid,
  p_expected_candidate_version bigint,
  p_narrator_gender public.narrator_gender,
  p_voice_version_id uuid,
  p_command_id uuid,
  p_idempotency_key text,
  p_request_hash text,
  p_correlation_id uuid
)
returns jsonb
language plpgsql
security definer
set search_path = ''
as $$
declare
  actor_id uuid := auth.uid();
  candidate public.episode_configuration_candidates%rowtype;
  episode_version bigint;
  response jsonb;
  selected_voice_status public.voice_version_availability_status;
begin
  if actor_id is null then
    raise exception 'authentication required' using errcode = '42501';
  end if;
  perform private.assert_active_session(p_workspace_id);
  perform pg_catalog.pg_advisory_xact_lock(
    pg_catalog.hashtextextended(
      p_workspace_id::text || actor_id::text || p_idempotency_key,
      0
    )
  );
  response := private.existing_command_response(
    p_workspace_id,
    actor_id,
    p_idempotency_key,
    'episode.voice.select',
    p_request_hash
  );
  if response is not null then return response; end if;

  select * into candidate
  from public.episode_configuration_candidates c
  where c.workspace_id = p_workspace_id
    and c.episode_id = p_episode_id
    and c.id = p_configuration_candidate_id
  for update;
  if not found or candidate.state <> 'world_design' then
    raise exception 'active world configuration not found' using errcode = 'P0002';
  end if;
  if p_expected_candidate_version is null
    or candidate.aggregate_version is distinct from p_expected_candidate_version
  then
    raise exception 'stale configuration candidate' using errcode = '40001';
  end if;
  select a.status into selected_voice_status
  from public.voice_versions v
  join public.voice_version_availability a on a.voice_version_id = v.id
  where v.id = p_voice_version_id
    and v.gender = p_narrator_gender
  for update of a;
  if not found or selected_voice_status = 'withdrawn' then
    raise exception 'exact voice version is unavailable' using errcode = '23503';
  end if;

  update public.episode_configuration_candidates
  set narrator_gender = p_narrator_gender,
      voice_version_id = p_voice_version_id,
      voice_confirmed_by = actor_id,
      voice_confirmed_at = statement_timestamp(),
      selected_by = actor_id,
      aggregate_version = aggregate_version + 1
  where id = p_configuration_candidate_id
  returning * into candidate;

  update public.episodes
  set aggregate_version = aggregate_version + 1
  where workspace_id = p_workspace_id and id = p_episode_id
  returning aggregate_version into episode_version;
  update private.aggregate_versions as aggregate_state
  set current_version = aggregate_state.current_version + 1,
      updated_at = statement_timestamp()
  where aggregate_state.workspace_id = p_workspace_id
    and aggregate_state.aggregate_type = 'episode'
    and aggregate_state.aggregate_id = p_episode_id;

  perform private.emit_domain_event(
    p_workspace_id,
    'episode.voice_selected.v1',
    'episode',
    p_episode_id,
    episode_version,
    p_correlation_id,
    jsonb_build_object(
      'episodeId', p_episode_id,
      'configurationCandidateId', candidate.id,
      'configurationVersion', candidate.aggregate_version,
      'narratorGender', p_narrator_gender,
      'performanceProfileId', candidate.performance_profile_id,
      'selectionOrigin', 'human_confirmed',
      'confirmedAt', candidate.voice_confirmed_at,
      'confirmedBy', candidate.voice_confirmed_by,
      'voiceVersionId', p_voice_version_id
    )
  );
  response := jsonb_build_object(
    'ok', true,
    'configurationCandidateId', candidate.id,
    'configurationVersion', candidate.aggregate_version,
    'episodeVersion', episode_version,
    'narratorGender', p_narrator_gender,
    'performanceProfileId', candidate.performance_profile_id,
    'selectionOrigin', 'human_confirmed',
    'confirmedAt', candidate.voice_confirmed_at,
    'confirmedBy', candidate.voice_confirmed_by,
    'voiceVersionId', p_voice_version_id
  );
  perform private.record_command(
    p_command_id,
    p_workspace_id,
    actor_id,
    p_idempotency_key,
    'episode.voice.select',
    'episode',
    p_episode_id,
    p_expected_candidate_version,
    p_request_hash,
    response,
    p_correlation_id
  );
  perform private.insert_audit_event(
    p_workspace_id,
    'episode.voice.select',
    'episode_configuration_candidate',
    candidate.id,
    candidate.aggregate_version,
    p_command_id,
    p_idempotency_key,
    p_correlation_id,
    'allow',
    'accepted'
  );
  return response;
end;
$$;

